# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# 운영 프로파일 (application-prod.yml) 에서 사용됩니다.
# 로컬 개발은 H2 인메모리 DB를 사용하므로 이 값이 필요 없습니다.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=econdashboard
DB_USERNAME=econdashboard
DB_PASSWORD=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── External API Keys ────────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data)
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html (무료)
# 제공 데이터: VIX, CPI, 10Y국채, Fed Funds Rate, 실업률
FRED_API_KEY=
